menu "Alexa Wake-on-LAN"

    config WOL_DEVICE_NAME
        string "Nombre inicial del dispositivo"
        default "Encender PC"
        help
            Nombre descriptivo mostrado en los logs. Alexa permite cambiar el
            nombre después del emparejamiento Matter.

    config WOL_TARGET_MAC
        string "MAC de la computadora"
        default ""
        help
            Dirección MAC del adaptador de red que recibirá el Magic Packet,
            con formato AA:BB:CC:DD:EE:FF.

    config WOL_UDP_PORT
        int "Puerto UDP Wake-on-LAN"
        default 9
        range 1 65535

    config WOL_REPEAT_COUNT
        int "Cantidad de Magic Packets"
        default 3
        range 1 10

    config WOL_REPEAT_DELAY_MS
        int "Pausa entre paquetes (ms)"
        default 100
        range 0 2000

    config WOL_NETWORK_WAIT_SECONDS
        int "Espera máxima por IPv4 (s)"
        default 20
        range 1 120

    config WOL_MOMENTARY_RESET_MS
        int "Tiempo para regresar el interruptor a OFF (ms)"
        default 1000
        range 100 10000
        help
            El dispositivo se comporta como un pulsador: Alexa lo enciende,
            se envía Wake-on-LAN y después vuelve automáticamente a apagado.

endmenu
